extends ../layout

block content
  .container(style="max-width: 900px; margin: 0 auto; width: 100%;")
    
    //- header do fluxo
    .flex-header(style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 2rem;")
      div
        a(href=`/fluxos/${fluxo.id}` style="color: var(--text-dim); text-decoration: none; font-size: 0.9rem; display: inline-flex; align-items: center; gap: 0.5rem;") 
          i.ph.ph-arrow-left
          | Voltar à Edição do Fluxo
        h2(style="margin-top: 0.5rem;") #{fluxo.nome} (Ativos/Erro)

    if successMsg
      .status-badge(style="background: rgba(16, 185, 129, 0.1); color: #10b981; margin-bottom: 1rem;") ✅ Operação realizada com sucesso!

    .card(style="background: var(--card-bg); padding: 2rem; border-radius: 16px; border: 1px solid rgba(255,255,255,0.1);")
      
      h3(style="margin-bottom: 1.5rem;") Acompanhamento de Execuções
      
      if contatosFluxo && contatosFluxo.length > 0
        table(style="width: 100%; border-collapse: collapse; text-align: left;")
          thead
            tr(style="border-bottom: 1px solid rgba(255,255,255,0.1); color: var(--text-dim); font-size: 0.9rem;")
              th(style="padding: 0.75rem;") Para
              th(style="padding: 0.75rem;") Etapa Atual
              th(style="padding: 0.75rem;") Próxima Check/Envio
              th(style="padding: 0.75rem;") Status
              th(style="padding: 0.75rem; text-align: right;") Ações
          tbody
            each c in contatosFluxo
              tr(style="border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 0.95rem;")
                td(style="padding: 0.75rem;")
                  div(style="font-weight: 600;")= c.nome || "Desconhecido"
                  div(style="font-size: 0.8rem; color: var(--text-dim);")= c.telefone
                td(style="padding: 0.75rem;") Etapa #{c.etapa_atual}
                td(style="padding: 0.75rem;")
                  div= new Date(c.proxima_execucao).toLocaleDateString('pt-BR')
                  div(style="color: var(--text-dim); font-size: 0.8rem;")= new Date(c.proxima_execucao).toLocaleTimeString('pt-BR')
                
                td(style="padding: 0.75rem;")
                  if c.status === 'ERRO'
                    span(style="background: rgba(239, 68, 68, 0.1); color: #ef4444; padding: 4px 8px; border-radius: 4px; font-size: 0.8rem; font-weight: 600;") ERRO
                  else
                    span(style="background: rgba(56, 189, 248, 0.1); color: var(--primary); padding: 4px 8px; border-radius: 4px; font-size: 0.8rem; font-weight: 600;") ATIVO
                
                td(style="padding: 0.75rem; text-align: right;")
                  div(style="display: flex; gap: 0.5rem; justify-content: flex-end;")
                    if c.status === 'ERRO'
                      //- Botão Retomar
                      form(action=`/fluxos/execucao/${c.execucao_id}/retomar` method="POST" style="margin: 0;")
                        input(type="hidden" name="redirecionar_para_fluxo" value=fluxo.id)
                        button(type="submit" title="Retomar Execução" style="background: rgba(16, 185, 129, 0.2); color: #10b981; border: none; padding: 0.4rem 0.6rem; border-radius: 6px; cursor: pointer;")
                          i.ph.ph-play(style="font-size: 1.1rem;")
                    
                    //- Botão Cancelar
                    form(action=`/fluxos/execucao/${c.execucao_id}/cancelar` method="POST" style="margin: 0;")
                      input(type="hidden" name="redirecionar_para_fluxo" value=fluxo.id)
                      button(type="submit" title="Parar e Remover do Fluxo" style="background: rgba(239, 68, 68, 0.2); color: #ef4444; border: none; padding: 0.4rem 0.6rem; border-radius: 6px; cursor: pointer;")
                        i.ph.ph-x-circle(style="font-size: 1.1rem;")
      else
        p(style="color: var(--text-dim); text-align: center; padding: 2rem;") Não há contatos ativos ou em erro neste fluxo.
