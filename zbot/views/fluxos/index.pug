extends ../layout

block content
  .container(style="max-width: 800px; margin: 0 auto; width: 100%;")
    h2(style="margin-bottom: 1rem;") Gerenciar Fluxos
    
    if successMsg
      .status-badge(style="background: rgba(16, 185, 129, 0.1); color: #10b981; margin-bottom: 1rem;") ✅ Operação realizada com sucesso!

    .grid-container(style="display: grid; grid-template-columns: 1fr 2fr; gap: 2rem; margin-bottom: 2rem;")
      
      //- Criar Novo Fluxo
      .card(style="background: var(--card-bg); padding: 2rem; border-radius: 16px; border: 1px solid rgba(255,255,255,0.1);")
        h3(style="margin-bottom: 1.5rem;") Novo Fluxo
        form(action="/fluxos" method="POST" style="display: flex; flex-direction: column; gap: 1rem;")
          div
            label(style="display: block; margin-bottom: 0.5rem; color: var(--text-dim);") Nome do Fluxo
            input(type="text" name="nome" placeholder="Ex: Boas-vindas" required style="width: 100%; padding: 0.75rem; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; background: rgba(0,0,0,0.2); color: white;")

          button(type="submit" style="background: var(--primary); color: #0f172a; border: none; padding: 0.75rem; border-radius: 8px; font-weight: 600; cursor: pointer; margin-top: 1rem;") Criar Fluxo

      //- Lista de Fluxos
      .card(style="background: var(--card-bg); padding: 2rem; border-radius: 16px; border: 1px solid rgba(255,255,255,0.1);")
        h3(style="margin-bottom: 1rem;") Seus Fluxos
        
        if fluxos && fluxos.length > 0
          table(style="width: 100%; border-collapse: collapse; text-align: left;")
            thead
              tr(style="border-bottom: 1px solid rgba(255,255,255,0.1); color: var(--text-dim); font-size: 0.9rem;")
                th(style="padding: 0.75rem;") ID
                th(style="padding: 0.75rem;") Nome
                th(style="padding: 0.75rem; text-align: right;") Ações
            tbody
              each f in fluxos
                tr(style="border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 0.95rem;")
                  td(style="padding: 0.75rem; color: var(--text-dim);") ##{f.id}
                  td(style="padding: 0.75rem; font-weight: 600;")= f.nome
                  td(style="padding: 0.75rem; text-align: right;")
                    div(style="display: flex; gap: 0.5rem; justify-content: flex-end; align-items: center;")
                      button(type="button" title="Editar Nome" onclick=`openEditModal(${JSON.stringify(f)})` style="background: rgba(56, 189, 248, 0.2); color: var(--primary); border: none; padding: 0.4rem 0.6rem; border-radius: 6px; cursor: pointer;")
                        i.ph.ph-pencil(style="font-size: 1.1rem;")
                      
                      a(href=`/fluxos/${f.id}` style="background: rgba(56, 189, 248, 0.2); color: var(--primary); padding: 0.4rem 0.8rem; border-radius: 6px; text-decoration: none; font-size: 0.85rem;") Configurar Etapas
                      
                      form(action=`/fluxos/${f.id}/excluir` method="POST" style="margin: 0;" onsubmit="return confirm('Tem certeza que deseja excluir o fluxo inteiro? Isso apagará todas as etapas e interromperá contatos ativos.')")
                        button(type="submit" title="Excluir Fluxo" style="background: rgba(239, 68, 68, 0.2); color: #ef4444; border: none; padding: 0.4rem 0.6rem; border-radius: 6px; cursor: pointer;")
                          i.ph.ph-trash(style="font-size: 1.1rem;")
        else
          p(style="color: var(--text-dim); text-align: center; padding: 1rem;") Nenhum fluxo criado ainda.

  //- Modal de Edição de Nome do Fluxo
  #editModal(style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 1000; align-items: center; justify-content: center; backdrop-filter: blur(5px);")
    .card(style="background: var(--bg-dark); width: 90%; max-width: 400px; padding: 2rem; border-radius: 16px; border: 1px solid rgba(255,255,255,0.1); position: relative;")
      button(onclick="closeEditModal()" style="position: absolute; top: 1rem; right: 1rem; background: none; border: none; color: var(--text-dim); cursor: pointer; font-size: 1.5rem;") &times;
      h3(style="margin-bottom: 1.5rem;") Editar Nome do Fluxo
      
      form#editForm(method="POST")
        div(style="display: flex; flex-direction: column; gap: 1rem;")
          div(style="display: flex; flex-direction: column; gap: 0.5rem;")
            label(style="font-size: 0.9rem; color: var(--text-dim);") Novo Nome
            input#editNome(type="text" name="nome" required style="padding: 0.75rem; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; background: rgba(0,0,0,0.2); color: white;")
          
          button(type="submit" style="background: var(--primary); color: #0f172a; border: none; padding: 0.75rem; border-radius: 8px; font-weight: 600; cursor: pointer; margin-top: 1rem;") Atualizar Nome

  script.
    function openEditModal(fluxo) {
      document.getElementById('editForm').action = `/fluxos/${fluxo.id}/editar`;
      document.getElementById('editNome').value = fluxo.nome;
      document.getElementById('editModal').style.display = 'flex';
    }

    function closeEditModal() {
      document.getElementById('editModal').style.display = 'none';
    }

    window.onclick = function(event) {
      const modal = document.getElementById('editModal');
      if (event.target == modal) {
        closeEditModal();
      }
    }
