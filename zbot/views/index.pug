extends layout

block content
  style.
    .auth-card {
      background: var(--card-bg);
      width: 100%;
      max-width: 550px;
      margin: 2rem auto;
      padding: 3rem;
      border-radius: 24px;
      border: 1px solid rgba(255,255,255,0.1);
      text-align: center;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }
    
    .status-badge {
      display: inline-block;
      padding: 6px 16px;
      border-radius: 20px;
      background: rgba(56, 189, 248, 0.1);
      color: var(--primary);
      font-size: 0.85rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
      border: 1px solid rgba(56, 189, 248, 0.2);
      transition: all 0.3s ease;
    }

    .qr-wrapper {
      background: white;
      padding: 15px;
      border-radius: 16px;
      margin: 2rem auto;
      width: fit-content;
      display: none;
      animation: fadeIn 0.5s ease-out;
    }

    #qrcode { width: 220px; height: 220px; display: block; }

    .loading-spinner {
      margin: 2rem auto;
      width: 40px;
      height: 40px;
      border: 3px solid rgba(255,255,255,0.1);
      border-top: 3px solid var(--primary);
      border-radius: 50%;
      animation: spin 1s linear infinite;
    }

    @keyframes spin { to { transform: rotate(360deg); } }
    @keyframes fadeIn { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }

  section.auth-card
    h2(style="margin-bottom: 0.5rem; font-size: 1.75rem;") Conexão WhatsApp
    p(style="color: var(--text-dim); font-size: 0.95rem; line-height: 1.5;") Escaneie o código abaixo para autenticar o bot. <br> Apenas quando conectado o sistema processará os disparos.
    
    hr(style="margin: 2rem 0; border: 0; border-top: 1px solid rgba(255,255,255,0.1);")

    div#status-container
      span.status-badge#status Aguardando inicialização...
    
    div#loading.loading-spinner

    div#qrcode-container.qr-wrapper
      img#qrcode(src="", alt="QR Code de Conexão")

    div#success-msg(style="display: none; animation: fadeIn 0.5s ease-out;")
      i.ph-fill.ph-check-circle(style="font-size: 4rem; color: #10b981; margin-bottom: 1rem;")
      h3(style="margin-bottom: 0.5rem; color: #10b981;") Aparelho Conectado!
      p(style="color: var(--text-dim); margin-bottom: 2rem; font-size: 0.95rem;") O worker em plano de fundo agora enviará automaticamente as mensagens agendadas.
      
      div(style="display: flex; flex-direction: column; gap: 1rem; align-items: center; margin-top: 2rem;")
        div(style="display: flex; gap: 1rem; justify-content: center;")
          a(href="/contatos" style="background: rgba(255,255,255,0.05); color: white; text-decoration: none; padding: 0.75rem 1.5rem; border-radius: 8px; font-size: 0.95rem; border: 1px solid rgba(255,255,255,0.1); transition: background 0.2s;") Contatos
          a(href="/campanhas" style="background: var(--primary); color: #0f172a; text-decoration: none; padding: 0.75rem 1.5rem; border-radius: 8px; font-weight: 600; font-size: 0.95rem; transition: filter 0.2s;") Novas Campanhas
        
        form(action="/logout" method="POST" style="width: 100%; max-width: 300px;")
          button(type="submit" style="width: 100%; background: transparent; color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3); padding: 0.6rem; border-radius: 8px; cursor: pointer; font-size: 0.85rem; transition: all 0.2s;" onmouseover="this.style.background='rgba(239, 68, 68, 0.05)'" onmouseout="this.style.background='transparent'")
            i.ph.ph-sign-out(style="margin-right: 8px;")
            | Desconectar e trocar conta

  script(src="/socket.io/socket.io.js")
  script.
    const socket = io();
    const statusEl = document.getElementById('status');
    const qrEl = document.getElementById('qrcode');
    const qrCont = document.getElementById('qrcode-container');
    const loading = document.getElementById('loading');
    const successMsg = document.getElementById('success-msg');

    socket.on('qrCode', (base64) => {
      loading.style.display = 'none';
      qrCont.style.display = 'block';
      successMsg.style.display = 'none';
      qrEl.src = base64;
      statusEl.innerText = 'Pronto para Escanear';
      statusEl.style.color = '#38bdf8';
      statusEl.style.background = 'rgba(56, 189, 248, 0.1)';
      statusEl.style.borderColor = 'rgba(56, 189, 248, 0.2)';
    });

    socket.on('status', (status) => {
      // Se não for isLogged/CONNECTED, atualiza o texto normal
      if (!['isLogged', 'CONNECTED', 'qrReadSuccess', 'inChat'].includes(status)) {
        statusEl.innerText = status;
      }

      if (['isLogged', 'CONNECTED', 'qrReadSuccess', 'inChat'].includes(status)) {
        qrCont.style.display = 'none';
        loading.style.display = 'none';
        successMsg.style.display = 'block';
        statusEl.innerText = 'Conectado';
        statusEl.style.background = 'rgba(16, 185, 129, 0.1)';
        statusEl.style.color = '#10b981';
        statusEl.style.borderColor = 'rgba(16, 185, 129, 0.2)';
      }
    });
