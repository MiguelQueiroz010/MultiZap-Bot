doctype html
html(lang="pt-br")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title= title || "ZBot"
    link(rel="icon", type="image/png", href="/favicon.png")
    link(rel='stylesheet', href='/stylesheets/style.css')
    link(href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet")
    script(src="https://unpkg.com/@phosphor-icons/web")

    style.
      :root {
        --primary: #38bdf8;
        --bg-dark: #0f172a;
        --card-bg: rgba(30, 41, 59, 0.7);
        --text-main: #f1f5f9;
        --text-dim: #94a3b8;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        font-family: 'Inter', sans-serif;
        background: var(--bg-dark);
        color: var(--text-main);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      header {
        width: 100%;
        padding: 1rem 10%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: rgba(15, 23, 42, 0.95);
        border-bottom: 1px solid rgba(255,255,255,0.05);
        position: sticky;
        top: 0;
        z-index: 100;
      }

      .logo { display: flex; align-items: center; gap: 10px; font-weight: 700; font-size: 1.2rem; color: var(--primary); text-decoration: none; }
      nav a { color: var(--text-main); text-decoration: none; margin-left: 1.5rem; font-size: 0.95rem; }
      nav a:hover { color: var(--primary); }

      main {
        flex: 1;
        padding: 2rem 10%;
      }

      .grid-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        margin-bottom: 2rem;
      }

      /* Responsividade */
      @media (max-width: 768px) {
        header {
          flex-direction: column;
          gap: 1rem;
          padding: 1rem 5%;
        }
        nav {
          display: flex;
          flex-wrap: wrap;
          justify-content: center;
          gap: 0.5rem;
        }
        nav a { margin-left: 0; padding: 0.5rem; }
        main { padding: 1.5rem 5%; }
        
        .flex-header {
           flex-direction: column;
           align-items: flex-start !important;
           gap: 1rem;
        }
        .flex-header > div { width: 100%; }
        .flex-container { flex-direction: column; }
        .grid-container { grid-template-columns: 1fr !important; }
      }

  body
    header
      a.logo(href="/")
        i.ph-fill.ph-robot
        span ZBot
      nav(style="display: flex; align-items: center;")
        a(href="/") Conexão
        a(href="/contatos") Contatos
        a(href="/campanhas") Campanhas
        a(href="/fluxos") Fluxos
        a(href="/biblioteca") Acervo
        a(href="/filas") Filas & Erros
        form(action="/logout" method="POST" style="margin-left: 1.5rem;")
          button(type="submit" style="background: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2); padding: 0.4rem 0.8rem; border-radius: 6px; cursor: pointer; font-size: 0.85rem; font-weight: 600; transition: all 0.2s;" onmouseover="this.style.background='rgba(239, 68, 68, 0.2)'" onmouseout="this.style.background='rgba(239, 68, 68, 0.1)'")
            i.ph-bold.ph-power(style="margin-right: 5px;")
            | Sair

    main
      block content
