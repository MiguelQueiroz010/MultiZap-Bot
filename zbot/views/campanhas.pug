extends layout

block content
  .container(style="max-width: 800px; margin: 0 auto; width: 100%;")
    h2(style="margin-bottom: 1rem;") Campanhas
    
    if successMsg
      .status-badge(style="background: rgba(16, 185, 129, 0.1); color: #10b981; margin-bottom: 1rem;")
        if successMsg === 'criada'
          | ✅ Campanha criada e agendada na fila com sucesso!
        else if successMsg === 'no_contacts'
          | ⚠️ Nenhum contato cadastrado para envio.

    .grid-container(style="display: grid; gap: 2rem; margin-bottom: 2rem;")
      
      //- Criar Campanha
      .card(style="background: var(--card-bg); padding: 2rem; border-radius: 16px; border: 1px solid rgba(255,255,255,0.1);")
        h3(style="margin-bottom: 1.5rem;") Nova Campanha Simples
        form(action="/campanhas" method="POST" style="display: flex; flex-direction: column; gap: 1rem;")
          div(style="display: flex; flex-direction: column; gap: 0.5rem;")
            label(style="font-size: 0.9rem; color: var(--text-dim);") Enviar Para
            select(name="contato_id" style="padding: 0.75rem; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; background: rgba(0,0,0,0.2); color: white; cursor: pointer;")
              option(value="0") 🌍 Todos os Contatos (Global)
              each contact in contatosDocs
                option(value=contact.id) 👤 #{contact.nome} (#{contact.telefone.split('@')[0]})

          div(style="display: flex; flex-direction: column; gap: 0.5rem;")
            label(style="font-size: 0.9rem; color: var(--text-dim);") Mensagem (Opcional se usar Acervo)
            textarea#mensagem(name="mensagem" rows="4" placeholder="Digite o texto da campanha..." style="padding: 0.75rem; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; background: rgba(0,0,0,0.2); color: white; resize: vertical;")
          
          div(style="display: flex; align-items: center; gap: 10px; background: rgba(56, 189, 248, 0.05); padding: 10px; border-radius: 8px; border: 1px solid rgba(56, 189, 248, 0.1);")
            input#random_library(type="checkbox" name="random_library" value="1" style="width: 18px; height: 18px; cursor: pointer;")
            label(for="random_library" style="font-size: 0.9rem; cursor: pointer; font-weight: 600; color: var(--primary);")
              i.ph-bold.ph-shuffle(style="margin-right: 5px;")
              | Sortear do Acervo de Mensagens (Random)
          p(style="font-size: 0.75rem; color: var(--text-dim); margin-left: 28px; margin-top: -5px;") Se marcado, o sistema ignorará o texto acima e selecionará um item aleatório do seu Acervo para este envio.
          
          div(style="display: flex; gap: 1rem; align-items: center;")
            div(style="flex: 1;")
              label(style="display: block; margin-bottom: 0.5rem; color: var(--text-dim);") Delay Mín. (segundos)
              input(type="number" name="delay_min" min="1" value="10" required style="width: 100%; padding: 0.75rem; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; background: rgba(0,0,0,0.2); color: white;")
            div(style="flex: 1;")
              label(style="display: block; margin-bottom: 0.5rem; color: var(--text-dim);") Delay Máx. (segundos)
              input(type="number" name="delay_max" min="1" value="30" required style="width: 100%; padding: 0.75rem; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; background: rgba(0,0,0,0.2); color: white;")
          
          div(style="margin-top: 0.5rem;")
            label(style="display: block; margin-bottom: 0.5rem; color: var(--text-dim); font-size: 0.9rem;") Iniciar Disparos Em (Opcional)
            input(type="datetime-local" name="data_agendamento" style="width: 100%; padding: 0.75rem; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; background: rgba(0,0,0,0.2); color: white; cursor: pointer;")
          
          div(style="display: flex; align-items: center; gap: 0.5rem; margin-top: 0.5rem;")
            input(type="checkbox" id="recorrente" name="recorrente" value="1" style="width: 18px; height: 18px; cursor: pointer;")
            label(for="recorrente" style="color: var(--text-dim); cursor: pointer;") Repetir disparos todos os dias (Recorrência diária)

          button(type="submit" style="background: var(--primary); color: #0f172a; border: none; padding: 0.75rem 1.5rem; border-radius: 8px; font-weight: 600; cursor: pointer; margin-top: 1rem;") Disparar Campanha
          p(style="font-size: 0.8rem; color: var(--text-dim); margin-top: 0.5rem;") *O disparo não ocorre na requisição, um agendador rodará no fundo.

      //- Resumo Fila
      .card(style="background: var(--card-bg); padding: 2rem; border-radius: 16px; border: 1px solid rgba(255,255,255,0.1);")
        h3(style="margin-bottom: 1.5rem;") Status Fila Global
        
        .stat-box(style="background: rgba(0,0,0,0.2); padding: 1.5rem; border-radius: 8px; text-align: center; margin-bottom: 1rem;")
          h4(style="color: var(--text-dim); font-weight: 400; font-size: 0.9rem;") Pendentes
          p(style="font-size: 2rem; font-weight: 700; color: #fbbf24;")= stats.PENDENTE || 0

        .stat-box(style="background: rgba(0,0,0,0.2); padding: 1.5rem; border-radius: 8px; text-align: center; margin-bottom: 1rem;")
          h4(style="color: var(--text-dim); font-weight: 400; font-size: 0.9rem;") Enviadas
          p(style="font-size: 2rem; font-weight: 700; color: #10b981;")= stats.ENVIADO || 0

        .stat-box(style="background: rgba(0,0,0,0.2); padding: 1.5rem; border-radius: 8px; text-align: center;")
          h4(style="color: var(--text-dim); font-weight: 400; font-size: 0.9rem;") Erros
          p(style="font-size: 2rem; font-weight: 700; color: #ef4444;")= stats.ERRO || 0

    //- Histórico de Campanhas
    .card(style="background: var(--card-bg); padding: 2rem; border-radius: 16px; border: 1px solid rgba(255,255,255,0.1);")
      h3(style="margin-bottom: 1rem;") Histórico de Campanhas Criadas
      
      if campanhas && campanhas.length > 0
        .table-responsive(style="overflow-x: auto;")
          table(style="width: 100%; border-collapse: collapse; text-align: left;")
            thead
              tr(style="border-bottom: 1px solid rgba(255,255,255,0.1); color: var(--text-dim); font-size: 0.85rem; text-transform: uppercase;")
                th(style="padding: 1rem 0.75rem;") Tipo
                th(style="padding: 1rem 0.75rem;") Destinatário
                th(style="padding: 1rem 0.75rem;") Mensagem
                th(style="padding: 1rem 0.75rem;") Delays
                th(style="padding: 1rem 0.75rem;") Recorrência
                th(style="padding: 1rem 0.75rem;") Status
                th(style="padding: 1rem 0.75rem; text-align: right;") Ações
            tbody
              each c in campanhas
                tr(style="border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 0.95rem;")
                  td(style="padding: 1.25rem 0.75rem;")
                    if c.contato_id
                      span(style="background: rgba(56, 189, 248, 0.1); color: var(--primary); padding: 4px 8px; border-radius: 4px; font-size: 0.75rem; font-weight: 600;") INDIVIDUAL
                    else
                      span(style="background: rgba(16, 185, 129, 0.1); color: #10b981; padding: 4px 8px; border-radius: 4px; font-size: 0.75rem; font-weight: 600;") GLOBAL
                  td(style="padding: 1.25rem 0.75rem;")
                    if c.contato_id
                      div(style="font-weight: 600;")= c.contato_nome
                    else
                      div(style="color: var(--text-dim);") Todos os Contatos
                  td(style="padding: 1.25rem 0.75rem; max-width: 250px;")
                    if c.random_library
                      span(style="color: var(--primary); font-style: italic;") 🎲 Sorteio do Acervo
                    else
                      div(style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;")= c.mensagem
                  td(style="padding: 1.25rem 0.75rem; color: var(--text-dim); font-size: 0.85rem;") #{c.delay_min}s - #{c.delay_max}s
                  td(style="padding: 1.25rem 0.75rem;")
                    if c.recorrente
                      span(title="Repete a cada 24 horas" style="color: #10b981; display: flex; align-items: center; gap: 4px; font-size: 0.85rem;") 
                        i.ph-bold.ph-arrows-clockwise
                        | Diária
                    else
                      span(style="color: var(--text-dim);") Não
                  td(style="padding: 1.25rem 0.75rem;")
                    if c.friendlyStatus === 'Finalizado'
                      span(style="background: rgba(16, 185, 129, 0.1); color: #10b981; padding: 4px 8px; border-radius: 4px; font-size: 0.75rem; font-weight: 700; border: 1px solid rgba(16, 185, 129, 0.2);") FINALIZADO
                    else if c.friendlyStatus === 'Em Andamento'
                      span(style="background: rgba(56, 189, 248, 0.1); color: var(--primary); padding: 4px 8px; border-radius: 4px; font-size: 0.75rem; font-weight: 700; border: 1px solid rgba(56, 189, 248, 0.2);") ENVIANDO...
                    else if c.friendlyStatus === 'Agendado'
                      span(style="background: rgba(251, 191, 36, 0.1); color: #fbbf24; padding: 4px 8px; border-radius: 4px; font-size: 0.75rem; font-weight: 700; border: 1px solid rgba(251, 191, 36, 0.2);") AGENDADO
                    else
                      span(style="background: rgba(255,255,255,0.05); color: var(--text-dim); padding: 4px 8px; border-radius: 4px; font-size: 0.75rem;")= c.friendlyStatus

                  td(style="padding: 1.25rem 0.75rem; text-align: right;")
                    div(style="display: flex; gap: 8px; justify-content: flex-end; align-items: center;")
                      if c.friendlyStatus === 'Finalizado'
                        form(action=`/campanhas/${c.id}/reiniciar` method="POST" style="margin: 0;")
                          button(type="submit" title="Disparar Novamente" style="background: rgba(16, 185, 129, 0.15); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.2); padding: 0.5rem; border-radius: 8px; cursor: pointer; transition: all 0.2s;")
                            i.ph-bold.ph-play-circle(style="font-size: 1.1rem;")
                      
                      button(type="button" title="Editar Campanha" onclick=`openEditCampaignModal(${JSON.stringify(c)})` style="background: rgba(56, 189, 248, 0.15); color: var(--primary); border: 1px solid rgba(56, 189, 248, 0.2); padding: 0.5rem; border-radius: 8px; cursor: pointer; transition: all 0.2s;")
                        i.ph-bold.ph-pencil-simple(style="font-size: 1.1rem;")

                      form(action=`/campanhas/${c.id}/excluir` method="POST" style="margin: 0; display: inline-block;" onsubmit="return confirm('Tem certeza? Isso apagará os agendamentos pendentes desta campanha.')")
                        button(type="submit" title="Excluir Campanha" style="background: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2); padding: 0.5rem; border-radius: 8px; cursor: pointer; transition: all 0.2s;")
                          i.ph-bold.ph-trash(style="font-size: 1.1rem;")
      else
        .empty-state(style="text-align: center; padding: 3rem 1rem;")
          i.ph-bold.ph-megaphone(style="font-size: 3rem; color: var(--text-dim); margin-bottom: 1rem; display: block;")
          p(style="color: var(--text-dim);") Nenhuma campanha criada ainda.

  //- Modal de Edição de Campanha
  #editCampaignModal(style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 1000; align-items: center; justify-content: center; backdrop-filter: blur(5px);")
    .card(style="background: var(--bg-dark); width: 90%; max-width: 500px; padding: 2rem; border-radius: 16px; border: 1px solid rgba(255,255,255,0.1); position: relative;")
      button(onclick="closeEditCampaignModal()" style="position: absolute; top: 1rem; right: 1rem; background: none; border: none; color: var(--text-dim); cursor: pointer; font-size: 1.5rem;") &times;
      h3(style="margin-bottom: 1.5rem;") Editar Campanha
      
      form#editCampaignForm(method="POST")
        div(style="display: flex; flex-direction: column; gap: 1rem;")
          div(style="display: flex; flex-direction: column; gap: 0.5rem;")
            label(style="font-size: 0.9rem; color: var(--text-dim);") Mensagem
            textarea#editMensagem(name="mensagem" rows="4" style="padding: 0.75rem; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; background: rgba(0,0,0,0.2); color: white; resize: vertical;")
          
          div(style="display: flex; gap: 1rem;")
            div(style="flex: 1;")
              label(style="font-size: 0.9rem; color: var(--text-dim);") Delay Mín (s)
              input#editDelayMin(type="number" name="delay_min" min="1" required style="width:100%; padding: 0.75rem; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; background: rgba(0,0,0,0.2); color: white;")
            div(style="flex: 1;")
              label(style="font-size: 0.9rem; color: var(--text-dim);") Delay Máx (s)
              input#editDelayMax(type="number" name="delay_max" min="1" required style="width:100%; padding: 0.75rem; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; background: rgba(0,0,0,0.2); color: white;")
          
          button(type="submit" style="background: var(--primary); color: #0f172a; border: none; padding: 0.75rem; border-radius: 8px; font-weight: 600; cursor: pointer; margin-top: 1rem;") Salvar Alterações

  script.
    const cbRandom = document.getElementById('random_library');
    const txtMsg = document.getElementById('mensagem');

    if (cbRandom && txtMsg) {
      cbRandom.addEventListener('change', () => {
        if (cbRandom.checked) {
          txtMsg.removeAttribute('required');
          txtMsg.style.opacity = '0.5';
          txtMsg.placeholder = 'Mensagens serão sorteadas do Acervo...';
        } else {
          txtMsg.setAttribute('required', '');
          txtMsg.style.opacity = '1';
          txtMsg.placeholder = 'Digite o texto da campanha...';
        }
      });
    }

    function openEditCampaignModal(campanha) {
      document.getElementById('editCampaignForm').action = `/campanhas/${campanha.id}/editar`;
      document.getElementById('editMensagem').value = campanha.mensagem;
      document.getElementById('editDelayMin').value = campanha.delay_min;
      document.getElementById('editDelayMax').value = campanha.delay_max;
      
      const editMsgField = document.getElementById('editMensagem');
      if (campanha.random_library) {
        editMsgField.readOnly = true;
        editMsgField.style.opacity = '0.5';
        editMsgField.placeholder = "Campanha utiliza Acervo Random.";
      } else {
        editMsgField.readOnly = false;
        editMsgField.style.opacity = '1';
      }

      document.getElementById('editCampaignModal').style.display = 'flex';
    }

    function closeEditCampaignModal() {
      document.getElementById('editCampaignModal').style.display = 'none';
    }
